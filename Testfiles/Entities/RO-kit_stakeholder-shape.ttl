@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix aps: <https://w3id.org/nfdi4ing/profiles/> .

<https://identifier.buildingsmart.org/uri/nbs/uniclass2015/1/class/Ro_30_40_54> rdfs:label "Manufacturer" .
<https://identifier.buildingsmart.org/uri/nbs/uniclass2015/1/class/Ro_50_10_03> rdfs:label "Architect" .
<https://identifier.buildingsmart.org/uri/nbs/uniclass2015/1/class/Ro_50_20_11> rdfs:label "Engineer" .


aps:e65fc010-5fe6-4d74-9333-8601c31dde5d
  dcterms:created "2026-04-28"^^xsd:date ;
  dcterms:creator "Roger Winkler" ;
  dcterms:description "RO-kit stakeholder node shape for organizations involved in a building project."@en ;
  dcterms:license <http://creativecommons.org/licenses/by/4.0/> ;
  dcterms:subject <https://github.com/tibonto/dfgfo/410-01> ;
  dcterms:title "RO-kit stakeholder node shape"@en ;
  a sh:NodeShape ;
  rdfs:label "RO-kit stakeholder"@en ;
  owl:imports aps:3a566450-14ce-432d-9d10-9e1c83b8477a ;
  sh:closed false ;
  sh:property [
    sh:order 1 ;
    sh:name "Organization" ;
    sh:description "Organization acting as a stakeholder in the building project."@en ;
    sh:path prov:agent ;
    sh:class foaf:Organisation ;
    sh:node aps:3a566450-14ce-432d-9d10-9e1c83b8477a ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ], [
    sh:order 2 ;
    sh:name "Role" ;
    sh:description "Project role of the stakeholder."@en ;
    sh:path schema:roleName ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:in (
        <https://identifier.buildingsmart.org/uri/nbs/uniclass2015/1/class/Ro_30_40_54> # Manufacturer
        <https://identifier.buildingsmart.org/uri/nbs/uniclass2015/1/class/Ro_50_10_03> # Architect
        <https://identifier.buildingsmart.org/uri/nbs/uniclass2015/1/class/Ro_50_20_11> # Engineer
    ) ;
  ] .
